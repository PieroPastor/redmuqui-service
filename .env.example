# Copia este archivo como ".env" y completa los valores reales.
# Cárgalo con `export $(grep -v '^#' .env | xargs)` o con python-dotenv.

DJANGO_SECRET_KEY=cambia-esto-por-algo-aleatorio
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=*

# --- AWS / S3 ---
AWS_REGION=us-east-1
AWS_S3_BUCKET=nombre-de-tu-bucket
S3_DOCUMENTOS_PREFIX=documentos/

# En AWS Academy, si el EC2 tiene el LabRole asociado, deja estas 3 vacías:
# boto3 toma las credenciales automáticamente desde el rol de la instancia.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# --- Backend Spring Boot ---
SPRING_BACKEND_URL=http://localhost:8080
# Usuario "de servicio" creado en la BD del backend con rol que tenga DOCUMENTOS_UPDATE (ej. TECNICO)
SPRING_SERVICE_EMAIL=ocr-service@redmuqui.local
SPRING_SERVICE_PASSWORD=cambia-esto

# --- Webhook (push desde Spring Boot) ---
# Debe coincidir con OCR_WEBHOOK_TOKEN / ocr.webhook.token en el backend.
OCR_WEBHOOK_TOKEN=cambia-esto-por-un-token-aleatorio

# --- Poller de respaldo (no es la vía principal, solo atrapa lo que el webhook no notificó) ---
POLL_INTERVAL_SECONDS=300
OCR_LANGUAGES=spa+eng
OCR_DESCRIPCION_RESULTADO=PDF generado automáticamente por OCR a partir del archivo original.
